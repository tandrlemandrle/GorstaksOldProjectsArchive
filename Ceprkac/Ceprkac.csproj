<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>0.6.5.0</Version>
    <AssemblyName>Ceprkac</AssemblyName>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifiers>win-x64;win-x86</RuntimeIdentifiers>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>Ceprkac.ico</ApplicationIcon>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.1938.49" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="blocklist.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
